command = /opt/homebrew/bin/tmux -f /Users/josh/.config/tmux/tmux.conf
abnormal-command-exit-runtime = 0

# Disable title management from shell integration
# See ~/.zshrc for the other half of this setup
shell-integration-features = no-title

# window
gtk-tabs-location = bottom
window-new-tab-position = end
unfocused-split-opacity = 0.85

# cursor
cursor-style-blink = false
shell-integration-features = no-cursor
cursor-style = block

# mouse
mouse-hide-while-typing = true
copy-on-select = true
mouse-scroll-multiplier = 0.1

# keybindings
keybind = cmd+k=ignore
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down

# Make it hard to accidentally nuke the window
confirm-close-surface = true
keybind = super+q=ignore
keybind = super+w=ignore
keybind = super+alt+w=ignore
keybind = super+shift+w=ignore
keybind = super+alt+shift+w=ignore

# text
font-feature = -calt
window-inherit-font-size = true
keybind = shift+enter=text:\x1b\r
